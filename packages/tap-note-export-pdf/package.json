{
  "name": "@tap-note/export-pdf",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "description": "TapNote PDF 格式导出器：基于 @react-pdf/renderer 将 BlockNote 文档渲染为 PDF。",
  "scripts": {
    "lint": "eslint",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "@blocknote/core": "0.51.4",
    "@react-pdf/renderer": "^4.5.1",
    "@tap-note/export-core": "workspace:*"
  },
  "peerDependencies": {
    "react": "^19"
  },
  "devDependencies": {
    "@eslint/js": "^10",
    "@happy-dom/global-registrator": "^18.0.0",
    "@types/react": "^19",
    "eslint": "^10",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "typescript": "~6",
    "typescript-eslint": "^8"
  },
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*"
  }
}

{
  "name": "@workspace/server-api",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "description": "TapNote 自托管 AI 网关:Hono + AI SDK v7,提供内联写作 streamText、对话 chat、模型列表、审批代理示例。",
  "scripts": {
    "lint": "eslint",
    "format": "prettier --write \"**/*.{ts,tsx}\"",

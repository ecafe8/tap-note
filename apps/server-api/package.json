    "test": "bun test",
    "dev": "bun run --hot src/index.ts"
  },
  "dependencies": {
    "@ai-sdk/alibaba": "2.0.14",
    "@ai-sdk/google": "4.0.18",
    "@hono/node-server": "2.0.10",
    "@tap-note/ai-core": "workspace:*",
    "ai": "7.0.31",
    "dotenv": "17.4.2",
    "hono": "4.12.30",
    "jose": "6.2.3",
    "pino": "10.3.1",
    "pino-pretty": "13.1.3",
    "zod": "^3.25.76 || ^4.1.8"
  },
  "devDependencies": {
    "@eslint/js": "^10",
    "@happy-dom/global-registrator": "^18.0.0",
    "@testing-library/jest-dom": "^6.8.0",
    "@types/bun": "^1",
    "eslint": "^10",
    "globals": "^17",
    "typescript": "~6",
    "typescript-eslint": "^8"
  },
  "exports": {
    ".": "./src/index.ts"
  }

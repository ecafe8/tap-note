# === 必填 ===
DASHSCOPE_API_KEY=

# === AI Provider（可选）===
DASHSCOPE_BASE_URL=
GOOGLE_GENERATIVE_AI_API_KEY=
GOOGLE_GENERATIVE_BASE_URL=

# === JWT 认证（可选，未配置时跳过校验，仅开发/演示模式）===
JWT_ISSUER=
JWT_AUDIENCE=
JWT_VERIFY_KEY=
JWT_ALGORITHMS=RS256,ES256

# === 服务 ===
PORT=4100
NODE_ENV=development
LOG_LEVEL=info
CORS_ORIGIN=http://localhost:5173
MODELS_PUBLIC=false

# === 上下文 ===
CONTEXT_MAX_TOKENS=30000

# === 限流 ===
RATE_LIMIT_RPM=10
RATE_LIMIT_CONCURRENCY=3
RATE_LIMIT_MAX_MESSAGES=20
RATE_LIMIT_MAX_INPUT_TOKENS=30000
RATE_LIMIT_MAX_OUTPUT_TOKENS=30000
RATE_LIMIT_MAX_TOOL_ROUNDS=5
RATE_LIMIT_MAX_STREAM_DURATION_SEC=60
